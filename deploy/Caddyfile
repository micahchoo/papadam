{$DOMAIN} {
    # API + auth + admin
    reverse_proxy /api/*    api:8000
    reverse_proxy /auth/*   api:8000
    reverse_proxy /nimda/*  api:8000
    reverse_proxy /static/* api:8000
    reverse_proxy /schema/* api:8000

    # CRDT WebSocket
    reverse_proxy /ws/*     crdt:1234

    # MinIO (if minio profile active)
    reverse_proxy /minio/*  minio:9000

    # Docs (if docs profile active)
    reverse_proxy /docs/*   docs:8001

    # Runtime config — fetched by SvelteKit SPA on startup
    reverse_proxy /config.json  api:8000
    reverse_proxy /healthcheck/ api:8000

    # SvelteKit SPA — serve static build, fall back to index.html
    root * /srv/ui
    file_server
    try_files {path} /index.html

    encode gzip

    request_body {
        max_size 500MB
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
