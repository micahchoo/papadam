# papadam — local development environment
# Copy to api/service_config.env (this file is gitignored).
#
# These settings assume you are running the data services from deploy/dev.yml:
#   docker compose -f deploy/dev.yml up -d
#
# Nothing here is secret — these are throwaway local dev values.

# Django
DJANGO_APP_ENV=local
DJANGO_SECRET_KEY=local-dev-not-a-secret-change-in-production
DJANGO_PAGINATION_LIMIT=50
PORT=8000

# Database — matches the dev.yml postgres service
DB_URL=postgres://papadam:devpassword@localhost:5432/papadam

# Redis — matches the dev.yml redis service
REDIS_URL=redis://localhost:6379/0

# File storage — MinIO running in dev.yml
PAPAD_FILE_STORAGE_TYPE=minio
PAPAD_STORAGE_BUCKET_NAME=papadam
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_S3_ENDPOINT_URL=http://localhost:9000

# Not needed locally (leave blank)
AWS_S3_ENDPOINT_URL=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION_NAME=
DJANGO_AWS_STORAGE_BUCKET_NAME=papadam

# CRDT server (leave blank — persistence is optional in local dev)
CRDT_API_URL=http://localhost:8000
CRDT_SERVER_TOKEN=local-crdt-dev-token

# Frontend URLs (only used by /config.json endpoint — not needed for local dev)
PUBLIC_API_URL=http://localhost:8000
PUBLIC_CRDT_URL=ws://localhost:1234

# Error tracking (leave blank)
SENTRY_KEY=

# Domain (not used in local dev)
DOMAIN=localhost
POSTGRES_PASSWORD=devpassword
