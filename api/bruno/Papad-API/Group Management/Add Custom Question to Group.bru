meta {
  name: Add Custom Question to Group
  type: http
  seq: 11
}

put {
  url: {{base_url}}/group/add_question/10/
  body: multipartForm
  auth: none
}

headers {
  Content-Type: multipart/form-data
  Authorization: Token {{auth_token}}
}

body:multipart-form {
  question: customdatapoint6
  mandatory: False
  type: number
  default_value: 150
  add_default_value: False
}
